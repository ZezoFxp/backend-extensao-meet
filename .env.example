# ─────────────────────────────────────────────────────
# Credenciais OAuth 2.0 da conta HOST (que agenda)
# Gere o refresh token rodando: npm run get-token
# ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SEU_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=SEU_REFRESH_TOKEN

# E-mail da conta host (quem cria as reuniões)
HOST_EMAIL=host@suaempresa.com

# Chave secreta que a extensão deve enviar em cada request
# Troque por uma string aleatória longa
EXTENSION_API_KEY=troque-por-uma-chave-secreta-longa-aqui

# Porta do servidor
PORT=3000

# Origens permitidas (CORS) — adicione a URL do seu servidor se publicar
ALLOWED_ORIGINS=chrome-extension://SEU_EXTENSION_ID
